---
import { indicators } from '@/data/indicators'
import { Icon } from 'astro-icon/components'

const { text } = Astro.props

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/'
---

<div class="flex flex-col">
  <h1 class="text-4xl py-8">Observatorio de Salud</h1>
  <p class="text-slate-600">{text}</p>
  <h2 class="text-2xl py-8">Problema de Salud Priorizado</h2>
  <p>
    La deserción escolar y el suicidio son problemas de salud pública que
    afectan significativamente a la población en el departamento de Huila.
  </p>
  <ul class="mt-6 flex flex-row gap-4">
    {
      indicators.map(
        (ind) =>
          ind.priority && (
            <li class="w-1/2">
              <a
                href={`${base}${ind.slug}`}
                class="h-full rounded-lg border bg-fuchsia-100 border-fuchsia-300 p-4 hover:border-blue-400 hover:shadow-sm hover:bg-blue-100 transition-all flex gap-5"
              >
                <div>
                  {ind.category === 'Brechas' ? (
                    <Icon
                      name="fa6-solid:people-pulling"
                      size={48}
                      class="text-fuchsia-500 m-4"
                    />
                  ) : (
                    <Icon
                      name="roentgen:two-people-together"
                      size={80}
                      class="text-fuchsia-500"
                    />
                  )}
                </div>
                <div class="flex flex-col">
                  <h2 class="mt-1 text-xl font-semibold text-gray-900">
                    {ind.title}
                  </h2>
                  <p class="mt-1 text-sm text-gray-600">{ind.description}</p>
                </div>
              </a>
            </li>
          ),
      )
    }
  </ul>
</div>
