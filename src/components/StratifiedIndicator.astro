---
import { StratifiedLineChart } from './StratifiedLineChart'
import type { StratifiedRow } from '@/lib/parquet'

interface Props {
  title: string
  text: string
  data: StratifiedRow[]
  yAxisLabel?: string
  csvPath?: string
}

const { title, text, data, yAxisLabel, csvPath } = Astro.props
---

<div class="mx-auto max-w-7xl px-2 sm:px-6 lg:px-10">
  <div class="flex flex-col gap-4">
    <h1 class="text-3xl font-bold my-6">{title}</h1>
    <p class="text-gray-700">{text}</p>

    <StratifiedLineChart
      client:load
      data={data}
      yAxisLabel={yAxisLabel}
      csvPath={csvPath}
    />
  </div>
</div>
