---
import { maternalMortalityIndicators as indicators } from '@/data/indicators'

const { title, text } = Astro.props

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/'

type IndicatorItem = (typeof indicators)[number]

const grouped = indicators.reduce<Record<string, Record<string, IndicatorItem[]>>>(
  (acc, ind) => {
    acc[ind.dimension] ??= {}
    acc[ind.dimension][ind.subdimension] ??= []
    acc[ind.dimension][ind.subdimension].push(ind)
    return acc
  },
  {},
)
---

<div class="mx-auto max-w-7xl px-2 sm:px-6 lg:px-10">
  <div class="flex flex-col gap-2">
    <h1 class="text-3xl font-bold my-6">{title}</h1>
    <p class="text-gray-700">{text}</p>

    <div class="flex gap-3 items-center mt-4">
      <span class="text-sm text-gray-600 font-medium">Ver indicadores de:</span>
      <div
        class="flex rounded-lg border border-gray-300 overflow-hidden text-sm"
      >
        <button
          id="category-btn-dss"
          type="button"
          aria-pressed="true"
          class="px-4 py-2 font-medium bg-gray-800 text-white transition-colors"
        >
          Determinantes Sociales de la Salud
        </button>
        <button
          id="category-btn-policy"
          type="button"
          aria-pressed="false"
          class="px-4 py-2 font-medium bg-white text-gray-700 hover:bg-gray-50 transition-colors"
        >
          Política
        </button>
      </div>
    </div>

    <div id="indicators-container" class="mt-6 flex flex-col gap-8">
      {
        Object.entries(grouped).map(([dimension, subdimensions]) => (
          <div data-dimension={dimension}>
            {Object.entries(subdimensions).map(([subdimension, items]) => (
              <div class="mb-8">
                <h2 class="text-base font-semibold uppercase tracking-wide text-gray-500 mb-3 capitalize">
                  {subdimension}
                </h2>
                <ul class="flex flex-col gap-4">
                  {items.map((ind) => (
                    <li>
                      <a
                        href={`${base}${ind.slug}`}
                        class="block rounded-lg border border-gray-200 p-4 hover:border-blue-400 hover:shadow-sm transition-all"
                      >
                        <h3 class="mt-1 text-lg font-semibold text-gray-900">
                          {ind.title}
                        </h3>
                        <p class="mt-1 text-sm text-gray-600">
                          {ind.description}
                        </p>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        ))
      }
    </div>

    <p id="empty-message" class="text-gray-500 italic mt-4 hidden">
      No hay indicadores disponibles para esta dimensión.
    </p>
  </div>
</div>
<script>
  function getInitialDimension(): string {
    const params = new URLSearchParams(window.location.search)
    const dimension = params.get('dimension')
    return dimension === 'dss' || dimension === 'policy' ? dimension : 'dss'
  }

  let selectedDimension = getInitialDimension()

  function filterIndicators() {
    const groups = document.querySelectorAll<HTMLDivElement>(
      '#indicators-container [data-dimension]',
    )
    let visibleCount = 0

    groups.forEach((group) => {
      if (group.getAttribute('data-dimension') === selectedDimension) {
        group.style.display = ''
        visibleCount++
      } else {
        group.style.display = 'none'
      }
    })

    const emptyMessage = document.getElementById('empty-message')
    if (emptyMessage) {
      emptyMessage.classList.toggle('hidden', visibleCount > 0)
    }
  }

  function updateToggle() {
    const btnDss = document.getElementById('category-btn-dss')
    const btnPolicy = document.getElementById('category-btn-policy')

    if (selectedDimension === 'dss') {
      btnDss?.classList.add('bg-gray-800', 'text-white')
      btnDss?.classList.remove('bg-white', 'text-gray-700', 'hover:bg-gray-50')
      btnPolicy?.classList.remove('bg-gray-800', 'text-white')
      btnPolicy?.classList.add('bg-white', 'text-gray-700', 'hover:bg-gray-50')
      btnDss?.setAttribute('aria-pressed', 'true')
      btnPolicy?.setAttribute('aria-pressed', 'false')
    } else {
      btnPolicy?.classList.add('bg-gray-800', 'text-white')
      btnPolicy?.classList.remove(
        'bg-white',
        'text-gray-700',
        'hover:bg-gray-50',
      )
      btnDss?.classList.remove('bg-gray-800', 'text-white')
      btnDss?.classList.add('bg-white', 'text-gray-700', 'hover:bg-gray-50')
      btnPolicy?.setAttribute('aria-pressed', 'true')
      btnDss?.setAttribute('aria-pressed', 'false')
    }
  }

  function setDimension(dimension: string) {
    selectedDimension = dimension
    updateToggle()
    filterIndicators()
    history.replaceState(null, '', `?dimension=${dimension}`)
  }

  document
    .getElementById('category-btn-dss')
    ?.addEventListener('click', () => setDimension('dss'))

  document
    .getElementById('category-btn-policy')
    ?.addEventListener('click', () => setDimension('policy'))

  updateToggle()
  filterIndicators()
</script>
