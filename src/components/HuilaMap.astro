---
import { HuilaMapPanel } from './HuilaMapPanel'

interface Props {
  title: string
  text: string
  geojsonUrl: string
  csvUrl?: string
}

const { title, text, geojsonUrl, csvUrl } = Astro.props
---

<div class="flex flex-col gap-2">
  <h1 class="text-3xl font-bold my-6">{title}</h1>
  <p class="text-gray-700">{text}</p>
  <HuilaMapPanel geojsonUrl={geojsonUrl} csvUrl={csvUrl} client:only="react" />
</div>
