---
import Education from '@/components/Education.astro'
import Layout from '../layouts/Layout.astro'
import SuicideMortality from '@/components/SuicideMortality.astro'
import HuilaMap from '@/components/HuilaMap.astro'
import Analytics from '@/components/Analytics.astro'
import ForestPlot from '@/components/ForestPlot.astro'
import Welcome from '@/components/Welcome.astro'
import Catalog from '@/components/Catalog.astro'
import {
  readParquet,
  dataPath,
  filterSuicideRows,
  pivotGaps,
  filterEducationRows,
  filterAnalyticsRows,
  filterForestPlotRows,
  buildAnalyticsData,
  buildForestPlotData,
} from '../lib/parquet'
import { indicators } from '../data/indicators'

import type {
  SuicideRow,
  SuicideDataRow,
  GapsRow,
  GapsChartPoint,
  EducationRow,
  EducationDataRow,
  AnalyticsRow,
  AnalyticsDataRow,
  ForestPlotRow,
  ForestPlotDataRow,
} from '../lib/parquet'

export async function getStaticPaths() {
  let suicideData: SuicideDataRow[] = []
  let suicideRawRows: SuicideRow[] = []
  try {
    suicideRawRows = await readParquet<SuicideRow>(
      dataPath('suicide_huila.parquet'),
    )
    suicideData = filterSuicideRows(suicideRawRows)
  } catch (e) {
    console.error(e)
  }

  let suicideGapsData: GapsChartPoint[] = []
  try {
    const rows = await readParquet<GapsRow>(
      dataPath('suicide_huila_gaps.parquet'),
    )
    suicideGapsData = pivotGaps(rows)
  } catch (e) {
    console.error(e)
  }

  let educationData: EducationDataRow[] = []
  let educationRawRows: EducationRow[] = []
  try {
    educationRawRows = await readParquet<EducationRow>(
      dataPath('education_suaza.parquet'),
    )
    educationData = filterEducationRows(educationRawRows)
  } catch (e) {
    console.error(e)
  }

  let analyticsData: AnalyticsDataRow[] = []
  try {
    // Prefer the pre-built analytics parquet (generated by analytics_suaza.R)
    const rows = await readParquet<AnalyticsRow>(
      dataPath('analytics_suaza.parquet'),
    )
    analyticsData = filterAnalyticsRows(rows)
  } catch {
    // Fallback: derive at build time from already-loaded suicide + education rows
    analyticsData = buildAnalyticsData(suicideRawRows, educationRawRows)
  }

  let forestPlotData: ForestPlotDataRow[] = []
  try {
    const rows = await readParquet<ForestPlotRow>(
      dataPath('forest_plot_suaza.parquet'),
    )
    forestPlotData = filterForestPlotRows(rows)
  } catch {
    // Fallback: compute from already-loaded suicide + education rows
    forestPlotData = buildForestPlotData(suicideRawRows, educationRawRows)
  }

  const pages = [
    {
      slug: undefined,
      title: 'Inicio',
      text: 'Bienvenidos al Observatorio de Salud, un espacio dedicado a la recopilación, análisis y visualización de datos relacionados con la salud. Nuestro objetivo es proporcionar información precisa y actualizada para apoyar la toma de decisiones informadas en el ámbito de la salud pública.',
      date: '2026-01-01',
      navbar: true,
    },
    {
      slug: 'inequidades-en-salud',
      title: 'Inequidades en Salud',
      text: 'Problemas, gráficos de tendencias y mediciones de brechas',
      date: '2026-01-01',
      data: educationData,
      navbar: true,
    },
    {
      slug: 'determinantes-de-la-salud',
      title: 'Determinantes Sociales de la Salud',
      text: 'Factores que influyen en la salud de la población',
      date: '2026-01-01',
      navbar: true,
    },
    {
      slug: 'mapa-huila',
      title: 'Mapa Municipal de Huila',
      text: 'Comparación de indicadores de salud entre los municipios del departamento de Huila, Colombia. El mapa permite comparar a Suaza con los demás municipios de su departamento.',
      description:
        'Mapa coroplético interactivo que compara indicadores de salud por municipio en el departamento de Huila.',
      date: '2026-01-01',
      category: 'Salud',
      navbar: true,
    },
    ...indicators.map((ind) => ({
      slug: ind.slug,
      title: ind.title,
      text: ind.text,
      date: ind.date,
      navbar: ind.navbar,
      ...(ind.slug === 'mortalidad-suicidio'
        ? { data: suicideData, gapsData: suicideGapsData }
        : {}),
      ...(ind.slug === 'inequidades-en-salud' ? { data: educationData } : {}),
      ...(ind.slug === 'desercion-suicidio' ? { data: analyticsData } : {}),
      ...(ind.slug === 'correlacion-suaza' ? { data: forestPlotData } : {}),
    })),
  ]

  return pages.map(({ slug, title, text, date, navbar, ...rest }) => ({
    params: { slug },
    props: { title, text, pages, slug, date: new Date(date), navbar, ...rest },
  }))
}

const { title, text, pages, slug, date, data, gapsData } = Astro.props as {
  title: string
  text: string
  pages: unknown[]
  slug: string | undefined
  date: Date
  data?:
    | SuicideDataRow[]
    | EducationDataRow[]
    | AnalyticsDataRow[]
    | ForestPlotDataRow[]
  gapsData?: GapsChartPoint[]
}
---

<Layout title={title} text={text} date={date} pages={pages} currentPage={slug}>
  {slug === undefined && <Welcome text={text} />}
  {
    slug === 'determinantes-de-la-salud' && (
      <Catalog title={title} text={text} />
    )
  }
  {
    slug === 'inequidades-en-salud' && (
      <Education
        title={title}
        text={text}
        data={data as EducationDataRow[]}
        csvPath={`${import.meta.env.BASE_URL}/data/education_suaza.csv`}
      />
    )
  }
  {
    slug === 'mortalidad-suicidio' && (
      <SuicideMortality
        title={title}
        text={text}
        data={data as SuicideDataRow[]}
        gapsData={gapsData}
        csvPath={`${import.meta.env.BASE_URL}/data/suicide_huila.csv`}
        gapsCsvPath={`${import.meta.env.BASE_URL}/data/suicide_huila_gaps.csv`}
      />
    )
  }
  {
    slug === 'desercion-suicidio' && (
      <Analytics
        title={title}
        text={text}
        data={data as AnalyticsDataRow[]}
        csvPath={`${import.meta.env.BASE_URL}/data/analytics_suaza.csv`}
      />
    )
  }
  {
    slug === 'correlacion-suaza' && (
      <ForestPlot
        title={title}
        text={text}
        data={data as ForestPlotDataRow[]}
        csvPath={`${import.meta.env.BASE_URL}/data/forest_plot_suaza.csv`}
      />
    )
  }
  {
    slug === 'mapa-huila' && (
      <HuilaMap
        title={title}
        text={text}
        geojsonUrls={{
          cobertura_bruta: `${import.meta.env.BASE_URL}/data/huila_cobertura_bruta.geojson`,
          cobertura_neta: `${import.meta.env.BASE_URL}/data/huila_cobertura_neta.geojson`,
          deserci_n: `${import.meta.env.BASE_URL}/data/huila_desercion.geojson`,
          aprobaci_n: `${import.meta.env.BASE_URL}/data/huila_aprobacion.geojson`,
          reprobaci_n: `${import.meta.env.BASE_URL}/data/huila_reprobacion.geojson`,
          repitencia: `${import.meta.env.BASE_URL}/data/huila_repitencia.geojson`,
        }}
        csvUrl={`${import.meta.env.BASE_URL}/data/huila_map.csv`}
      />
    )
  }
</Layout>
